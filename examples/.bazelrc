# Minumum C++ version. Override it building this project with
# `bazel build --cxxopt='-std=c++<XY>' --host_cxxopt='c++<XY>' ...`
# (Both -std and --host_cxxopt must be set to force the desired version.)
build --cxxopt='-std=c++17' --host_cxxopt='-std=c++17'

# This sets -std=c++17 in the copt of *.mm files. See
# https://github.com/bazelbuild/bazel/issues/5318.
build --per_file_copt='.*\.mm\$@-std=c++17'

# Silence all C/C++ warnings in external code.
#
# Note that this will not silence warnings from external headers included
# in project code.
build --per_file_copt=external/.*@-w
build --host_per_file_copt=external/.*@-w

# Bazel 8/9 requires a registered test toolchain by default, which fails on Apple
# platforms in this workspace because there is no default test toolchain registered
# that targets iOS (tests are run on the macOS host via simulator instead).
# Setting this to false falls back to the legacy behavior where tests are executed
# without requiring a registered toolchain.
build --@bazel_tools//tools/test:incompatible_use_default_test_toolchain=false
